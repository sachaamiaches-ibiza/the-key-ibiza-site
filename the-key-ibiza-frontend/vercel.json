{
  "redirects": [
    {
      "source": "/villa-:slug(.*)",
      "destination": "https://the-key-ibiza-backend.vercel.app/share/villa/:slug",
      "statusCode": 307,
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Slackbot|TelegramBot|Discordbot).*"
        }
      ]
    },
    {
      "source": "/yacht-:slug(.*)",
      "destination": "https://the-key-ibiza-backend.vercel.app/share/yacht/:slug",
      "statusCode": 307,
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Slackbot|TelegramBot|Discordbot).*"
        }
      ]
    },
    {
      "source": "/blog-:slug(.*)",
      "destination": "https://the-key-ibiza-backend.vercel.app/share/blog/:slug",
      "statusCode": 307,
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Slackbot|TelegramBot|Discordbot).*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/wishlist/:code",
      "destination": "https://the-key-ibiza-backend.vercel.app/share/wishlist/:code"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|assets/|favicon|apple-touch).*)",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
