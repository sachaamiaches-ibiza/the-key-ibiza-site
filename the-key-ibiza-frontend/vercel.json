{
  "rewrites": [
    {
      "source": "/villa-:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(?:WhatsApp|facebookexternalhit|Twitterbot|LinkedInBot|TelegramBot|Slackbot).*"
        }
      ],
      "destination": "https://the-key-ibiza-backend.vercel.app/og/villa/:slug*"
    },
    {
      "source": "/yacht-:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(?:WhatsApp|facebookexternalhit|Twitterbot|LinkedInBot|TelegramBot|Slackbot).*"
        }
      ],
      "destination": "https://the-key-ibiza-backend.vercel.app/og/yacht/:slug*"
    },
    {
      "source": "/blog-:slug*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(?:WhatsApp|facebookexternalhit|Twitterbot|LinkedInBot|TelegramBot|Slackbot).*"
        }
      ],
      "destination": "https://the-key-ibiza-backend.vercel.app/og/blog/:slug*"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
