{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/villa-:slug*",
      "destination": "/api/villa?slug=:slug*"
    },
    {
      "source": "/yacht-:slug*",
      "destination": "/api/yacht?slug=:slug*"
    },
    {
      "source": "/blog-:slug*",
      "destination": "/api/blog?slug=:slug*"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|assets/|api/).*)",
      "destination": "/index.html"
    }
  ]
}
